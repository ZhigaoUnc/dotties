	"userDefinedCss": [
		"/* ═══════════════════════════════════════════════════════════════",
		"   VIMIUM C — AMOLED BLOODMOON THEME",
		"   Pure black. Maroon as a whisper, not a shout.",
		"   ═══════════════════════════════════════════════════════════════ */",
		"",
		"/* #ui */",
		"",
		"* { /*insertroot*/",
		"  --bg:           #000000;",
		"  --fg:           #c8c8c8;",
		"  --border:       #2a0808;",
		"",
		"  --lhbg:         #000000;",
		"  --lhfg:         #c8c8c8;",
		"",
		"  --title:        #c8c8c8;",
		"  --title-accent: #9b2335;",
		"",
		"  --link:         #c8c8c8;",
		"  --link-accent:  #c8c8c8;",
		"",
		"  --nbg:          #000000;",
		"  --nfg:          #c8c8c8;",
		"  --nborder:      #2a0808;",
		"  --nlhbg:        #000000;",
		"  --nlhfg:        #c8c8c8;",
		"  --ntitle:       #c8c8c8;",
		"  --ntitle-accent:#9b2335;",
		"  --nlink:        #c8c8c8;",
		"  --nlink-accent: #c8c8c8;",
		"",
		"  --accent-fg:    #0d0d0d;",
		"",
		"  font-family: \"SF Mono\", \"Fira Code\", \"Cascadia Code\", Consolas, monospace;",
		"  font-size: 12px;",
		"}",
		"",
		"/* ── HUD ───────────────────────────────────────────────────── */",
		"",
		".HUD {",
		"  color: var(--title);",
		"  border-radius: 0;",
		"  max-width: 480px;",
		"  min-width: unset;",
		"  line-height: 20px;",
		"  padding: 4px 10px;",
		"  letter-spacing: 0.02em;",
		"}",
		"",
		".HUD.D {",
		"  color: var(--ntitle);",
		"}",
		"",
		".HUD:after {",
		"  background: var(--bg);",
		"  border: 1px solid var(--border);",
		"  border-radius: 3px;",
		"}",
		"",
		".HUD.D:after {",
		"  background: var(--nbg);",
		"  border: 1px solid var(--nborder);",
		"}",
		"",
		"/* ── LINK HINTS ────────────────────────────────────────────── */",
		"",
		".LH {",
		"  color: var(--lhfg);",
		"  background: var(--lhbg);",
		"  border: 1px solid var(--border);",
		"  border-radius: 2px;",
		"  padding: 1px 5px;",
		"  font-weight: 700;",
		"  font-size: 11px;",
		"  font-family: \"SF Pro Text\", \"Inter\", system-ui, sans-serif;",
		"}",
		"",
		".D .LH {",
		"  color: var(--nlhfg);",
		"  background: var(--nlhbg);",
		"  border: 1px solid var(--nborder);",
		"}",
		"",
		".MC {",
		"  color: var(--title-accent);",
		"}",
		"",
		".D .MC {",
		"  color: var(--ntitle-accent);",
		"}",
		"",
		"/* ═══════════════════════════════════════════════════════════════",
		"   VOMNIBAR",
		"   ═══════════════════════════════════════════════════════════════ */",
		"",
		"/* #omni */",
		"",
		"* { /*insertroot*/",
		"  --bg:           #000000;",
		"  --fg:           #c8c8c8;",
		"  --border:       rgba(42,8,8,0.9);",
		"",
		"  --accent-fg:    #0d0d0d;",
		"",
		"  --title:        #e0e0e0;",
		"  --title-accent: #9b2335;",
		"",
		"  --link:         #666666;",
		"  --link-accent:  #888888;",
		"",
		"  --nbg:          #000000;",
		"  --nfg:          #c8c8c8;",
		"  --naccent-fg:   #0d0d0d;",
		"  --nborder:      rgba(42,8,8,0.9);",
		"  --ntitle:       #e0e0e0;",
		"  --ntitle-accent:#9b2335;",
		"  --nlink:        #666666;",
		"  --nlink-accent: #888888;",
		"",
		"  --font-size:      14px;",
		"  --font-size-link: 12px;",
		"  --font-weight: normal;",
		"  --font: \"SF Mono\", \"Fira Code\", \"Cascadia Code\", Consolas, monospace;",
		"  --padding: 0px;",
		"",
		"  font-family: var(--font);",
		"}",
		"",
		"body {",
		"  border: 1px solid rgba(42,8,8,0.6);",
		"  border-radius: 6px;",
		"  overflow: hidden;",
		"}",
		"",
		"#bar, #input, #list {",
		"  background: var(--bg);",
		"  font-weight: var(--font-weight);",
		"  color: var(--fg);",
		"}",
		"",
		".has-dark #bar,",
		".has-dark #input,",
		".has-dark #list {",
		"  background: var(--nbg);",
		"}",
		"",
		"#bar {",
		"  padding: 10px 12px;",
		"  border-bottom: 1px solid rgba(42,8,8,0.4);",
		"}",
		"",
		"#bar::before {",
		"  content: \"⟩\";",
		"  position: absolute;",
		"  left: 14px;",
		"  z-index: 300;",
		"  padding: 6px 0;",
		"  font-weight: bold;",
		"  font-size: var(--font-size);",
		"  color: #5a1520;",
		"}",
		"",
		"#input {",
		"  padding: var(--padding) 34px;",
		"  color: var(--title);",
		"  border: none;",
		"  box-shadow: none;",
		"  caret-color: #9b2335;",
		"  font-size: var(--font-size);",
		"  font-family: var(--font);",
		"}",
		"",
		".has-dark #input {",
		"  color: var(--ntitle);",
		"}",
		"",
		".item.s,",
		".item:hover {",
		"  background-color: var(--accent-fg);",
		"  border-left: 2px solid #5a1520;",
		"  cursor: pointer;",
		"}",
		"",
		".has-dark .item.s,",
		".has-dark .item:hover {",
		"  background-color: var(--naccent-fg);",
		"  border-left: 2px solid #5a1520;",
		"}",
		"",
		".item .top {",
		"  color: var(--title);",
		"}",
		"",
		".has-dark .item .top {",
		"  color: var(--ntitle);",
		"}",
		"",
		".item .top .title {",
		"  font-size: var(--font-size);",
		"}",
		"",
		".item .top .title match {",
		"  color: var(--title-accent);",
		"  font-weight: 700;",
		"}",
		"",
		".has-dark .item .top .title match {",
		"  color: var(--ntitle-accent);",
		"}",
		"",
		".item .bottom a {",
		"  color: var(--link);",
		"  font-size: var(--font-size-link);",
		"}",
		"",
		".has-dark .item .bottom a {",
		"  color: var(--nlink);",
		"}",
		"",
		".item .bottom a match {",
		"  color: var(--link-accent);",
		"  text-decoration: none;",
		"  font-weight: 600;",
		"}",
		"",
		".has-dark .item .bottom a match {",
		"  color: var(--nlink-accent);",
		"}",
		"",
		"/* ═══════════════════════════════════════════════════════════════",
		"   FIND BAR",
		"   ═══════════════════════════════════════════════════════════════ */",
		"",
		"/* #find */",
		"",
		"* { /*insertroot*/",
		"  --bg:           #000000;",
		"  --fg:           #c8c8c8;",
		"  --title-accent: #9b2335;",
		"  --link-accent:  #888888;",
		"  --nbg:          #000000;",
		"  --ntitle-accent:#9b2335;",
		"  --nlink-accent: #888888;",
		"  font-family: \"SF Mono\", \"Fira Code\", Consolas, monospace;",
		"}",
		"",
		".r {",
		"  color: #c8c8c8;",
		"  background: var(--bg);",
		"  border: none;",
		"  border-top: 1px solid rgba(42,8,8,0.5);",
		"  box-shadow: none;",
		"}",
		"",
		".r.D {",
		"  color: #c8c8c8;",
		"  background: var(--nbg);",
		"}",
		"",
		"#i {",
		"  color: #e0e0e0;",
		"  caret-color: #9b2335;",
		"}",
		"",
		".D #i {",
		"  color: #e0e0e0;",
		"}",
		"",
		"::selection {",
		"  background: rgba(155, 35, 53, 0.3);",
		"  color: #ffffff;",
		"}",
		""
	],
	"vimSync": true
}
