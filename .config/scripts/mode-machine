#!/usr/bin/env bash
set -euo pipefail
export PATH="/usr/local/bin:$HOME/.local/bin:$PATH"
export HOME="${HOME:-$(getent passwd "$(id -un)" | cut -d: -f6)}"
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
# --- Paths (RAM disk) -------------------------------------------------------
MODE_FILE="/tmp/desktop_mode"
PAUSED_TOTAL="/tmp/total_paused_seconds"
PAUSE_START="/tmp/pause_start_time"
PREV_MODE="/tmp/previous_mode"
DESC_FILE="/tmp/toggl_desc"

# --- Helpers -----------------------------------------------------------------
read_mode() { cat "$MODE_FILE" 2>/dev/null || echo "IDLE"; }
write_mode() { printf '%s\n' "$1" >"$MODE_FILE"; }
read_paused() { cat "$PAUSED_TOTAL" 2>/dev/null || echo 0; }
write_desc() { printf '%s\n' "$1" >"$DESC_FILE"; }
clear_desc() { rm -f "$DESC_FILE"; }
cleanup_state() {
  write_mode "IDLE"
  rm -f "$PAUSED_TOTAL" "$PAUSE_START" "$PREV_MODE"
  clear_desc
}

accumulate_pause() {
  local start elapsed total
  start=$(cat "$PAUSE_START" 2>/dev/null || echo "")
  [[ -z "$start" ]] && return 0
  elapsed=$(($(date +%s) - start))
  total=$(($(read_paused) + elapsed))
  printf '%s\n' "$total" >"$PAUSED_TOTAL"
  rm -f "$PAUSE_START"
}

running_entry_json() {
  toggl list time-entry -j 2>/dev/null |
    python3 -c "
import sys, json
entries = json.load(sys.stdin)
for e in entries:
    if e.get('stop') is None:
        print(json.dumps({'id': e['id'], 'start': e['start']}))
        sys.exit(0)
print('null')
" 2>/dev/null || echo "null"
}

# --- Subcommands -------------------------------------------------------------

do_work() {
  accumulate_pause
  toggl start "WORK(Stu-dying)"
  write_mode "WORK"
  write_desc "WORK(Stu-dying)"
  printf '0\n' >"$PAUSED_TOTAL"
  rm -f "$PAUSE_START" "$PREV_MODE"
}

do_config() {
  accumulate_pause
  toggl start "CONFIGURING"
  write_mode "CONFIGS"
  write_desc "CONFIGURING"
  printf '0\n' >"$PAUSED_TOTAL"
  rm -f "$PAUSE_START" "$PREV_MODE"
}

do_pause() {
  local mode
  mode=$(read_mode)

  if [[ "$mode" == "PAUSED" ]]; then
    accumulate_pause
    write_mode "$(cat "$PREV_MODE" 2>/dev/null || echo "WORK")"
    rm -f "$PREV_MODE"
  else
    if [[ "$mode" == "IDLE" ]]; then
      # Check if there's a stray Toggl entry we can pause around
      local info desc
      info=$(toggl current 2>/dev/null || true)
      if [[ -n "$info" ]] && ! echo "$info" | grep -qi "no time entry"; then
        desc=$(echo "$info" | sed -n 's/.* – *\(.*\)/\1/p' | xargs)
        printf '%s\n' "WORK" >"$PREV_MODE"
        write_desc "$desc"
        printf '%s\n' "$(date +%s)" >"$PAUSE_START"
        write_mode "PAUSED"
      else
        echo "mode-machine: nothing active to pause" >&2
        exit 1
      fi
    else
      printf '%s\n' "$mode" >"$PREV_MODE"
      printf '%s\n' "$(date +%s)" >"$PAUSE_START"
      write_mode "PAUSED"
    fi
  fi
}

do_idle() {
  local mode total_paused entry_json entry_id start_time new_start
  mode=$(read_mode)
  [[ "$mode" == "IDLE" ]] && exit 0

  if [[ "$mode" == "PAUSED" ]]; then
    accumulate_pause
    rm -f "$PREV_MODE"
  fi

  total_paused=$(read_paused)
  entry_json=$(running_entry_json)

  toggl stop 2>/dev/null || true

  if [[ "$entry_json" != "null" && "$total_paused" -gt 0 ]]; then
    entry_id=$(printf '%s' "$entry_json" |
      python3 -c "import sys,json; print(json.load(sys.stdin)['id'])")
    start_time=$(printf '%s' "$entry_json" |
      python3 -c "import sys,json; print(json.load(sys.stdin)['start'])")

    new_start=$(python3 -c "
import sys
from datetime import datetime, timedelta
dt = datetime.fromisoformat(sys.argv[1].replace('Z', '+00:00'))
dt += timedelta(seconds=int(sys.argv[2]))
print(dt.strftime('%Y-%m-%dT%H:%M:%SZ'))
" "$start_time" "$total_paused")
    toggl edit "$entry_id" --start-time "$new_start" 2>/dev/null || true
  fi

  cleanup_state
}

do_adopt() {
  local info desc mode
  info=$(toggl current 2>/dev/null || true)
  if [[ -z "$info" ]] || echo "$info" | grep -qi "no time entry"; then
    echo "mode-machine: no active Toggl entry to adopt" >&2
    exit 1
  fi

  desc=$(echo "$info" | sed -n 's/.* – *\(.*\)/\1/p' | xargs)

  case "$desc" in
  *"WORK(Stu-dying)"*) mode="WORK" ;;
  *"CONFIGURING"*) mode="CONFIGS" ;;
  *"Hacking Dotfiles"*) mode="CONFIGS" ;;
  *) mode="WORK" ;;
  esac

  write_mode "$mode"
  write_desc "$desc"
  printf '0\n' >"$PAUSED_TOTAL"
  rm -f "$PAUSE_START" "$PREV_MODE"
}

do_sync() {
  local mode
  mode=$(read_mode)
  [[ "$mode" == "IDLE" ]] && return 0

  if toggl current 2>/dev/null | grep -q "No time entry is running"; then
    cleanup_state
  fi
}

usage() {
  cat <<EOF
Usage: mode-machine {work|config|pause|idle|adopt|sync}

  work     Start tracking "WORK(Stu-dying)", set WORK mode
  config   Start tracking "CONFIGURING", set CONFIGS mode
  pause    Toggle pause — micro-pauses are local (no API call)
  idle     Stop tracking, subtract paused time via PATCH, wipe state
  adopt    Import whatever Toggl is tracking right now into state
  sync     Heartbeat — force IDLE if cloud entry was stopped externally
EOF
}

# --- Dispatch ----------------------------------------------------------------
case "${1:-help}" in
work) do_work ;;
config) do_config ;;
pause) do_pause ;;
idle) do_idle ;;
adopt) do_adopt ;;
sync) do_sync ;;
help | -h | --help) usage ;;
*)
  usage >&2
  exit 2
  ;;
esac
