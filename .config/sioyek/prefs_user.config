new_command _dual_panelify python -m sioyek.dual_panelify /usr/bin/sioyek "%{file_path}" "%{command_text}"

new_command _embed_annotations python -m sioyek.embed_annotations /usr/bin/sioyek "%{local_database}" "%{shared_database}" "%{file_path}"

new_command _extract_highlights python -m sioyek.extract_highlights /usr/bin/sioyek "%{local_database}" "%{shared_database}" "%{file_path}" %{zoom_level}

new_command _add_text python -m sioyek.add_text /usr/bin/sioyek "%{local_database}" "%{shared_database}" "%{file_path}" "%{selection_begin_document}" "%{command_text}"

new_command _add_red_text python -m sioyek.add_text /usr/bin/sioyek "%{local_database}" "%{shared_database}" "%{file_path}" "%{selection_begin_document}" "%{command_text}" fontsize=5 text_color=255 0 0

new_command _translate python -m sioyek.translate /usr/bin/sioyek "%{selected_text}"

new_command _download_paper python -m sioyek.paper_downloader download /usr/bin/sioyek "%{paper_name}" "%{selected_text}"

search_url_w	https://en.wiktionary.org/wiki/

new_command _speak_text /home/unc/.config/scripts/sioyek_tts.py "%{selected_text}"

# TTS playback controls
new_command _tts_pause     python3 -c "import socket as s; c=s.socket(s.AF_UNIX); c.connect('/tmp/sioyek-tts.sock'); c.send(b'{ \"command\": [\"cycle\", \"pause\"] }\n'); c.close()"
new_command _tts_speed_up   python3 -c "import socket as s; c=s.socket(s.AF_UNIX); c.connect('/tmp/sioyek-tts.sock'); c.send(b'{ \"command\": [\"add\", \"speed\", 0.1] }\n'); c.close()"
new_command _tts_speed_down python3 -c "import socket as s; c=s.socket(s.AF_UNIX); c.connect('/tmp/sioyek-tts.sock'); c.send(b'{ \"command\": [\"add\", \"speed\", -0.1] }\n'); c.close()"
new_command _tts_stop      python3 -c "import socket as s; c=s.socket(s.AF_UNIX); c.connect('/tmp/sioyek-tts.sock'); c.send(b'{ \"command\": [\"quit\"] }\n'); c.close()"
